# Copie para .env.local e ajuste conforme sua VPN.
# O iniciar_tudo.sh carrega este arquivo automaticamente.

# PERFIL DE PERFORMANCE
AUTOMATION_PERFORMANCE_PROFILE=super-estavel

# GUARDIÃO VPN
VPN_ENFORCE_US=1
VPN_AUTO_CONNECT_US=1
VPN_BLOCK_IF_NOT_US=1
VPN_REQUIRED_COUNTRY=US

# Opção A (NetworkManager / nmcli):
# Use "auto" se houver exatamente 1 conexão VPN/WireGuard no nmcli.
VPN_US_NMCLI_CONNECTION=auto
# Exemplo com nome explícito:
# VPN_US_NMCLI_CONNECTION="Surfshark-USA"

# Opção B (comando custom da sua VPN CLI):
# Deixe esta linha vazia se usar a Opção A.
VPN_CONNECT_COMMAND=
# Exemplos:
# VPN_CONNECT_COMMAND="nordvpn connect United_States"
# VPN_CONNECT_COMMAND="protonvpn-cli connect --cc US"
# VPN_CONNECT_COMMAND="mullvad relay set location us && mullvad connect"

# Opção C (Proton VPN App no Ubuntu):
# Se você já está logado no Proton App, deixe ativo para fallback automático.
VPN_PROTON_API_FALLBACK=1
# Normalmente "gui". Só altere se souber o que está fazendo.
VPN_PROTON_CLIENT_TYPE=gui
# Confirmar na tela antes de iniciar o Proton automaticamente (1=sim, 0=não).
VPN_PROTON_CONFIRM_BEFORE_CONNECT=1
# Desligar VPN automaticamente quando encerrar o iniciar_tudo.sh (Ctrl+C).
VPN_DISCONNECT_ON_EXIT=1
# Se quiser, defina comando custom para derrubar a VPN:
# VPN_DISCONNECT_COMMAND="nordvpn disconnect"
# VPN_DISCONNECT_COMMAND="protonvpn-cli disconnect"
VPN_DISCONNECT_COMMAND=
# Derruba todas as conexões VPN/WireGuard ativas no nmcli ao sair.
VPN_DISCONNECT_ALL_NMCLI=1

# Tolerância de verificação geo
VPN_VERIFY_ATTEMPTS=5
VPN_VERIFY_DELAY_SECONDS=4
VPN_COUNTRY_CHECK_TIMEOUT=8

# Controle da API via bot (OpenClaw / ZoeBot)
# Defina token forte no servidor para autenticar /api/automation/bot/command.
AUTOMATION_BOT_TOKEN=
# 0 = exige token, 1 = desativa autenticação (não recomendado).
AUTOMATION_BOT_ALLOW_UNAUTH=0

# Arquivo com perfis de automação (usado por /api/automation/profiles e start-profile).
AUTOMATION_PROFILES_FILE=/opt/fba-automation/backend/config/automation_profiles.json
